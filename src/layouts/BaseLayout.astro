---
import '../styles/global.css';
import SkipLink from '../components/SkipLink.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SeoHead from '../components/SeoHead.astro';
import CookieConsent from '../components/CookieConsent.astro';
import { siteConfig } from '../config/site.config';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;
const pageTitle = title ?? siteConfig.metadata.title;

const analyticsRuntime = {
  provider: siteConfig.analytics.provider,
  requiresConsent: siteConfig.analytics.requiresConsent,
  plausibleDomain: siteConfig.analytics.plausibleDomain,
  ga4MeasurementId: siteConfig.analytics.ga4MeasurementId,
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {noindex && <meta name="robots" content="noindex" />}
    <title>{pageTitle}</title>
    <SeoHead title={pageTitle} description={description} />
  </head>
  <body data-analytics-config={JSON.stringify(analyticsRuntime)}>
    <SkipLink />
    <SiteHeader />
    <slot />
    <SiteFooter />
    <CookieConsent />
    <script>
      import { bootstrapAnalytics } from '../scripts/analytics-bootstrap.ts';

      const configElement = document.body.dataset.analyticsConfig;

      if (configElement) {
        bootstrapAnalytics(JSON.parse(configElement));
      }
    </script>
  </body>
</html>
