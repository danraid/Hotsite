---
import Container from '../ui/Container.astro';
import PrimaryButton from '../ui/PrimaryButton.astro';
import Prose from '../ui/Prose.astro';
import SecondaryButton from '../ui/SecondaryButton.astro';
import Section from '../ui/Section.astro';
import { siteConfig } from '../../config/site.config';
import { ctaFinalContent } from '../../content/cta-final';
import { buildWhatsAppUrl } from '../../utils/whatsapp';

const { paragraphs, primaryCtaLabel, secondaryCtaLabel } = ctaFinalContent;
const { primaryCta, whatsapp } = siteConfig;

// #TODO-whatsapp-number — habilitar quando número verificado estiver na config
const whatsappUrl = buildWhatsAppUrl(whatsapp);
const whatsappDisabled = whatsappUrl === null;
---

<Section id="cta-final" variant="emphasis" dataSectionId="cta-final" class="final-cta">
  <Container class="final-cta__container">
    <Prose class="final-cta__prose">
      {paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </Prose>

    <div class="final-cta__actions">
      <PrimaryButton
        href={primaryCta.href}
        label={primaryCtaLabel}
        external={primaryCta.external}
        ctaLocation="cta-final"
        class="final-cta__button"
      />
      <SecondaryButton
        href={whatsappUrl ?? '#'}
        label={secondaryCtaLabel}
        external={!whatsappDisabled}
        disabled={whatsappDisabled}
        ctaLocation="cta-final"
        class="final-cta__button"
      />
    </div>
  </Container>
</Section>

<style>
  :global(.final-cta.section--emphasis) {
    background-color: var(--color-surface-warm);
  }

  .final-cta__container {
    display: flex;
    flex-direction: column;
    gap: var(--space-block);
    align-items: center;
    text-align: center;
  }

  .final-cta__prose {
    margin: 0;
  }

  .final-cta__prose :global(p) {
    text-wrap: pretty;
  }

  .final-cta__actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    max-width: 24rem;
  }

  .final-cta__actions :global(.final-cta__button) {
    width: 100%;
  }

  @media (min-width: 768px) {
    .final-cta__actions {
      flex-direction: row;
      justify-content: center;
      max-width: none;
      width: auto;
    }

    .final-cta__actions :global(.final-cta__button) {
      width: auto;
    }
  }
</style>
