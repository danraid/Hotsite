---
import Container from '../ui/Container.astro';
import PrimaryButton from '../ui/PrimaryButton.astro';
import Prose from '../ui/Prose.astro';
import SecondaryButton from '../ui/SecondaryButton.astro';
import Section from '../ui/Section.astro';
import { siteConfig } from '../../config/site.config';
import { heroContent } from '../../content/hero';

const { primaryCta } = siteConfig;
---

<Section id="hero" dataSectionId="hero">
  <Container class="hero__container">
    <h1 class="hero__headline">{heroContent.headline}</h1>

    <Prose class="hero__prose">
      <p>{heroContent.supportingCopy}</p>
    </Prose>

    <div class="hero__ctas">
      <PrimaryButton
        href={primaryCta.href}
        label={heroContent.primaryCtaLabel}
        external={primaryCta.external}
        ctaLocation="hero"
        class="hero__cta"
      />
      <SecondaryButton
        href={heroContent.secondaryCtaHref}
        label={heroContent.secondaryCtaLabel}
        ctaLocation="hero"
        class="hero__cta"
      />
    </div>
  </Container>
</Section>

<style>
  .hero__container {
    display: flex;
    flex-direction: column;
    gap: var(--space-block);
  }

  .hero__headline {
    margin: 0;
    max-width: var(--content-max);
    font-family: var(--font-heading);
    font-size: var(--font-size-h1);
    font-weight: 500;
    line-height: var(--line-height-heading);
    color: var(--color-brand-primary);
    text-wrap: balance;
  }

  .hero__prose {
    margin: 0;
  }

  .hero__ctas {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .hero__ctas :global(.hero__cta) {
    width: 100%;
  }

  @media (min-width: 768px) {
    .hero__ctas {
      flex-direction: row;
      gap: 1rem;
    }

    .hero__ctas :global(.hero__cta) {
      width: auto;
    }
  }
</style>
