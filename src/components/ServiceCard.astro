---
import Prose from './ui/Prose.astro';
import SecondaryButton from './ui/SecondaryButton.astro';

interface Props {
  id: string;
  title: string;
  description: string[];
  ctaLabel: string;
  ctaHref: string;
  serviceName: string;
}

const { id, title, description, ctaLabel, ctaHref, serviceName } = Astro.props;
const isExternal = ctaHref.startsWith('http');
---

<article id={id} class="service-card" data-service-name={serviceName}>
  <h3 class="service-card__title">{title}</h3>

  <Prose class="service-card__prose">
    {description.map((paragraph) => <p>{paragraph}</p>)}
  </Prose>

  <div class="service-card__cta">
    <SecondaryButton
      href={ctaHref}
      label={ctaLabel}
      external={isExternal}
      ctaLocation={`atendimentos-${id}`}
    />
  </div>
</article>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-block);
    padding: var(--space-block);
    background-color: var(--color-surface-warm);
    border: 1px solid transparent;
    border-radius: 0.375rem;
    transition:
      box-shadow var(--transition-duration) var(--transition-easing),
      border-color var(--transition-duration) var(--transition-easing);
  }

  .service-card:hover {
    border-color: color-mix(in srgb, var(--color-accent-gold) 35%, transparent);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--color-brand-primary) 8%, transparent);
  }

  .service-card__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: var(--font-size-h3);
    font-weight: 500;
    line-height: var(--line-height-heading);
    color: var(--color-brand-primary);
    text-wrap: balance;
  }

  .service-card__prose {
    margin: 0;
    flex: 1;
  }

  .service-card__cta {
    margin-block-start: 0.25rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .service-card {
      transition: none;
    }
  }
</style>
