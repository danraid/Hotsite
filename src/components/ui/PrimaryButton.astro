---
interface Props {
  href: string;
  label: string;
  external?: boolean;
  disabled?: boolean;
  ctaLocation?: string;
  ctaType?: 'primary' | 'header';
  class?: string;
}

const {
  href,
  label,
  external = false,
  disabled = false,
  ctaLocation,
  ctaType = 'primary',
  class: className,
} = Astro.props;

const linkProps = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<a
  href={disabled ? undefined : href}
  class:list={['btn', 'btn--primary', className, { 'btn--disabled': disabled }]}
  aria-disabled={disabled || undefined}
  tabindex={disabled ? -1 : undefined}
  data-cta-location={ctaLocation}
  data-cta-type={ctaType}
  {...linkProps}
>
  {label}
</a>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0.625rem 1.5rem;
    font-family: var(--font-body);
    font-size: var(--font-size-body);
    font-weight: 500;
    line-height: 1.2;
    text-decoration: none;
    border: var(--focus-ring-width) solid transparent;
    border-radius: 0.25rem;
    cursor: pointer;
    touch-action: manipulation;
  }

  .btn--primary {
    color: var(--color-on-brand-primary);
    background-color: var(--color-brand-primary);
  }

  .btn--primary:hover {
    background-color: var(--color-brand-primary-hover);
  }

  .btn--primary:active {
    background-color: var(--color-brand-primary-active);
  }

  .btn:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: 2px;
  }

  .btn--disabled,
  .btn--disabled:hover,
  .btn--disabled:active {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
    background-color: var(--color-brand-primary);
  }
</style>
