---
interface Props {
  class?: string;
  as?: 'div' | 'section' | 'article';
}

const { class: className, as: Tag = 'div' } = Astro.props;
---

<Tag class:list={['container', className]}>
  <slot />
</Tag>

<style>
  .container {
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding-x);
  }
</style>
