---
import { siteConfig } from '../config/site.config';
import { shouldRenderCookieConsent } from '../lib/analytics';

const { analytics, footer } = siteConfig;
const showBanner = shouldRenderCookieConsent(analytics);
---

{
  showBanner && (
    <div
      id="cookie-consent"
      class="cookie-consent"
      role="region"
      aria-label="Consentimento de cookies"
      aria-live="polite"
      hidden
    >
      <div class="cookie-consent__inner">
        <p class="cookie-consent__text">
          Este site usa cookies de análise para melhorar a experiência.{' '}
          <a href={footer.privacyPolicyPath} class="cookie-consent__link">
            Política de privacidade
          </a>
        </p>
        <div class="cookie-consent__actions">
          <button type="button" class="cookie-consent__btn cookie-consent__btn--secondary" data-consent="rejected">
            Recusar
          </button>
          <button type="button" class="cookie-consent__btn cookie-consent__btn--primary" data-consent="accepted">
            Aceitar
          </button>
        </div>
      </div>
    </div>
  )
}

<script>
  import { getConsentState, setConsentState } from '../lib/analytics';

  function initCookieConsent() {
    const banner = document.getElementById('cookie-consent');

    if (!banner) {
      return;
    }

    if (getConsentState() !== null) {
      banner.hidden = true;
      return;
    }

    banner.hidden = false;

    banner.addEventListener('click', (event) => {
      const button = (event.target as Element).closest('[data-consent]');

      if (!(button instanceof HTMLButtonElement)) {
        return;
      }

      const value = button.dataset.consent;

      if (value !== 'accepted' && value !== 'rejected') {
        return;
      }

      setConsentState(value);
      banner.hidden = true;
    });
  }

  initCookieConsent();
</script>

<style>
  .cookie-consent {
    position: fixed;
    inset-inline: 0;
    inset-block-end: 0;
    z-index: var(--z-cookie-consent);
    padding: 1rem var(--container-padding-x);
    background-color: var(--color-surface-warm);
    border-block-start: 1px solid color-mix(in srgb, var(--color-accent-sage) 50%, transparent);
    box-shadow: 0 -0.25rem 1rem color-mix(in srgb, var(--color-brand-primary) 8%, transparent);
  }

  .cookie-consent[hidden] {
    display: none;
  }

  .cookie-consent__inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: var(--container-max);
    margin-inline: auto;
  }

  .cookie-consent__text {
    margin: 0;
    font-size: var(--font-size-small);
    line-height: var(--line-height-body);
    color: var(--color-text-primary);
    text-wrap: pretty;
  }

  .cookie-consent__link {
    color: var(--color-brand-primary);
    font-weight: 500;
    text-underline-offset: 0.15em;
  }

  .cookie-consent__link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: 2px;
    border-radius: 0.25rem;
  }

  .cookie-consent__actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cookie-consent__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    width: 100%;
    padding: 0.625rem 1.5rem;
    font-family: var(--font-body);
    font-size: var(--font-size-body);
    font-weight: 500;
    line-height: 1.2;
    border: var(--focus-ring-width) solid transparent;
    border-radius: 0.25rem;
    cursor: pointer;
    touch-action: manipulation;
  }

  .cookie-consent__btn:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: 2px;
  }

  .cookie-consent__btn--primary {
    color: var(--color-on-brand-primary);
    background-color: var(--color-brand-primary);
  }

  .cookie-consent__btn--primary:hover {
    background-color: var(--color-brand-primary-hover);
  }

  .cookie-consent__btn--secondary {
    color: var(--color-brand-primary);
    background-color: transparent;
    border-color: var(--color-accent-gold);
  }

  .cookie-consent__btn--secondary:hover {
    background-color: color-mix(in srgb, var(--color-accent-gold) 12%, transparent);
  }

  @media (min-width: 768px) {
    .cookie-consent__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
    }

    .cookie-consent__actions {
      flex-direction: row;
      flex-shrink: 0;
      width: auto;
    }

    .cookie-consent__btn {
      width: auto;
      min-width: 8rem;
    }
  }
</style>
